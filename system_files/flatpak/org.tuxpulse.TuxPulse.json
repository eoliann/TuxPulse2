{
  "app-id": "org.tuxpulse.TuxPulse",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "23.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "tuxpulse",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=host",
    "--talk-name=org.freedesktop.Flatpak",
    "--talk-name=org.freedesktop.Notifications"
  ],
  "modules": [
    {
      "name": "tuxpulse",
      "buildsystem": "simple",
      "build-commands": [
        "install -D tuxpulse /app/bin/tuxpulse"
      ],
      "sources": [
        {
          "type": "file",
          "path": "../../src-tauri/target/release/tuxpulse"
        }
      ]
    }
  ]
}
